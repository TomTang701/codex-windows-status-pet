#!/usr/bin/env sh

# Refuse accidental pushes when the local remote owner was never explicitly approved.
expected_owner="$(git config --local --get codex.expected-owner)"
remote_url="$(git remote get-url "$1" 2>/dev/null)"

case "$remote_url" in
  https://github.com/*/*|git@github.com:*/*)
    owner_repo="${remote_url#https://github.com/}"
    owner_repo="${owner_repo#git@github.com:}"
    remote_owner="${owner_repo%%/*}"
    ;;
  *)
    echo "Blocked: remote is not a GitHub repository URL." >&2
    exit 1
    ;;
esac

if [ -z "$expected_owner" ]; then
  echo "Blocked: set the approved GitHub owner first:" >&2
  echo "  git config --local codex.expected-owner <your-github-username>" >&2
  exit 1
fi

if [ "$remote_owner" != "$expected_owner" ]; then
  echo "Blocked: remote owner '$remote_owner' does not match approved owner '$expected_owner'." >&2
  exit 1
fi

expected_email="$(git config --local --get codex.expected-author-email)"
actual_email="$(git config --get user.email)"
if [ -z "$expected_email" ]; then
  echo "Blocked: set the approved commit author email first:" >&2
  echo "  git config --local codex.expected-author-email <github-noreply-email>" >&2
  exit 1
fi

if [ "$actual_email" != "$expected_email" ]; then
  echo "Blocked: commit author email '$actual_email' does not match approved email '$expected_email'." >&2
  exit 1
fi

exit 0
